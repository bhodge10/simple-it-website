<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {%- set effectiveTitle = post.metaTitle if post.metaTitle else post.title -%}
    {%- set effectiveDescription = post.metaDescription if post.metaDescription else post.excerpt -%}
    {%- set ogImage = post.ogImageUrl if post.ogImageUrl else 'https://simple-it.us/simple-it-logo.png' -%}
    {%- set siteUrl = 'https://simple-it.us/blog/' + post.slug + '/' -%}
    {%- set canonicalUrl = post.canonicalUrl if post.canonicalUrl else siteUrl -%}

    <title>{{ effectiveTitle }} | Simple IT</title>
    <meta name="description" content="{{ effectiveDescription }}">
    <link rel="canonical" href="{{ canonicalUrl }}">

    <link rel="icon" type="image/png" href="/simple-it-logo.png">

    <!-- Open Graph -->
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ effectiveTitle }}">
    <meta property="og:description" content="{{ effectiveDescription }}">
    <meta property="og:url" content="{{ siteUrl }}">
    <meta property="og:image" content="{{ ogImage }}">
    <meta property="og:site_name" content="Simple IT">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ effectiveTitle }}">
    <meta name="twitter:description" content="{{ effectiveDescription }}">
    <meta name="twitter:image" content="{{ ogImage }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/blog.css">

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W6T2XSC5NN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W6T2XSC5NN');
    </script>
    <script src="/attribution.js" defer></script>

    <!-- BlogPosting Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {{ post.title | dump | safe }},
      "description": {{ effectiveDescription | dump | safe }},
      "datePublished": "{{ post.publishedAt }}",
      "dateModified": "{{ post.updatedAt }}",
      "image": "{{ ogImage }}",
      "author": {
        "@type": "Person",
        "name": {{ post.author.fullName | dump | safe }},
        "url": "https://simple-it.us/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Simple IT, LLC",
        "logo": {
          "@type": "ImageObject",
          "url": "https://simple-it.us/simple-it-logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ siteUrl }}"
      }
    }
    </script>

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://simple-it.us/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://simple-it.us/blog/" },
        { "@type": "ListItem", "position": 3, "name": {{ post.title | dump | safe }}, "item": "{{ siteUrl }}" }
      ]
    }
    </script>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="nav-container">
            <a href="/" class="logo">Simple <span class="logo-highlight">IT</span></a>
            <ul class="nav-links">
                <li><a href="/our-services">Services</a></li>
                <li><a href="/#why-us">Why Us</a></li>
                <li><a href="/blog/">Blog</a></li>
                <li><a href="/remote-support" class="nav-support-btn">Remote Support</a></li>
                <li><a href="/submit-ticket.html" class="nav-ticket-btn">Open Ticket</a></li>
                <li><a href="/#contact" class="nav-cta">Get Started</a></li>
            </ul>
            <div class="contact-info">
                <span>&#128222; 859-449-7878</span>
            </div>
            <button class="mobile-menu-btn" aria-label="Toggle menu">&#9776;</button>
        </div>
    </nav>

    <!-- Breadcrumb -->
    <div class="blog-breadcrumb">
        <div class="blog-container">
            <a href="/">Home</a> / <a href="/blog/">Blog</a> / <span>{{ post.title }}</span>
        </div>
    </div>

    <!-- Article -->
    <article class="blog-article">
        <div class="blog-container">
            <header class="article-header">
                {% if post.tags and post.tags.length > 0 %}
                <div class="article-categories">
                    {% for tag in post.tags %}
                    <span class="category-tag">{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}

                <h1>{{ post.title }}</h1>

                <div class="article-meta">
                    <span class="meta-author">{{ post.author.fullName }}</span>
                    <span class="meta-separator">&#183;</span>
                    <time datetime="{{ post.publishedAtDate | htmlDateString }}">{{ post.publishedAtDate | readableDate }}</time>
                    <span class="meta-separator">&#183;</span>
                    <span class="meta-reading-time">{{ post.bodyHtml | readingTime }}</span>
                </div>
            </header>

            {% if post.ogImageUrl %}
            <div class="article-featured-image">
                <img src="{{ post.ogImageUrl }}" alt="{{ post.title }}" loading="lazy">
            </div>
            {% endif %}

            <div class="article-body">
                {{ post.bodyHtml | safe }}
            </div>

            <div class="article-cta">
                <h3>Need IT Help?</h3>
                <p>Simple IT provides guaranteed 15-minute response time IT support for businesses in Northern Kentucky and Cincinnati.</p>
                <div class="cta-actions">
                    <a href="tel:8594497878" class="cta-phone">&#128222; 859-449-7878</a>
                    <a href="/#contact" class="cta-assessment">Free IT Assessment</a>
                </div>
            </div>
        </div>
    </article>

    <footer>
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>SIMPLE IT</h3>
                <p>Business Technology Made Simple. Serving Northern Kentucky and Greater Cincinnati with guaranteed 15-minute response times.</p>
                <div class="social-links">
                    <a href="https://www.facebook.com/GoSimpleIT/" target="_blank">Facebook</a>
                    <a href="https://www.linkedin.com/company/simpleit-llc" target="_blank">LinkedIn</a>
                </div>
            </div>
            <div class="footer-section">
                <h4>Services</h4>
                <ul>
                    <li><a href="/managed-it-services">Managed IT</a></li>
                    <li><a href="/cybersecurity-solutions">Cybersecurity</a></li>
                    <li><a href="/cloud-solutions">Cloud Solutions</a></li>
                    <li><a href="/emergency-it-support">Emergency Support</a></li>
                    <li><a href="/business-continuity">Business Continuity</a></li>
                    <li><a href="/voip-phone-systems">VoIP Phone Systems</a></li>
                    <li><a href="/network-cabling">Network Cabling</a></li>
                    <li><a href="/security-cameras">Security Cameras</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Company</h4>
                <ul>
                    <li><a href="/about-us">About Us</a></li>
                    <li><a href="/blog/">Blog</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Contact</h4>
                <ul>
                    <li><a href="tel:8594497878">859-449-7878</a></li>
                    <li><a href="mailto:info@simple-it.us">info@simple-it.us</a></li>
                    <li>2220 Grandview Drive<br>Suite 250<br>Ft. Mitchell, KY 41017</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Simple IT, LLC. All rights reserved.</p>
            <div>
                <a href="/privacy-policy">Privacy Policy</a>
                <a href="/terms-of-service">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script>
        const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
        const navLinks = document.querySelector('.nav-links');
        if (mobileMenuBtn) {
            mobileMenuBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                navLinks.classList.toggle('active');
                mobileMenuBtn.textContent = navLinks.classList.contains('active') ? '✕' : '☰';
            });
            document.addEventListener('click', (e) => {
                if (!e.target.closest('nav')) {
                    navLinks.classList.remove('active');
                    mobileMenuBtn.textContent = '☰';
                }
            });
        }
    </script>
</body>
</html>
